<mvc:View
		controllerName="com.sap.pocompare.controller.First"
		xmlns:mvc="sap.ui.core.mvc"
		xmlns="sap.m"
		xmlns:f="sap.f"
		xmlns:layout="sap.ui.layout"
		xmlns:core="sap.ui.core"
		height="100%">
		<f:DynamicPage id="dynamicPageId" headerExpanded="{/headerExpanded}" toggleHeaderOnTitleClick="{/titleClickable}">
			<!-- DynamicPage Title -->
			<f:title>
				<f:DynamicPageTitle>
					<f:heading>
						<Title text="PO Excel Upload : "/>
					</f:heading>
					<f:expandedContent>
						<!-- <Label text="This is a subheading"/> -->
					</f:expandedContent>
					<f:snappedContent>
						<!-- <Label text="This is a subheading"/> -->
					</f:snappedContent>
					<f:snappedTitleOnMobile>
						<!-- <Title text="This is a subheading"/> -->
					</f:snappedTitleOnMobile>
					<f:content>
						<core:Fragment fragmentName="com.sap.pocompare.view.fragments.DynamicInput"
                                        type="XML"
                                    />
					</f:content>
					<f:actions>
						<Button
							text="Save Template"
							icon="sap-icon://excel-attachment"
							press=".onSaveTemplate"
						/>
						<Button
							visible="false"
							text="Download Template"
							icon="sap-icon://excel-attachment"
							press=".onDownloadTemplate"
						/>
					</f:actions>
					<f:navigationActions>
					</f:navigationActions>
				</f:DynamicPageTitle>
			</f:title>
			<!-- DynamicPage Header -->
			<f:content>
			<VBox>
                            <core:Fragment
                                fragmentName="com.sap.pocompare.view.fragments.sections.PODynamicDoubleTable"
                                type="XML"
                            />
			</VBox>
			</f:content>
			<!-- DynamicPage Footer -->
			<f:footer>
				<OverflowToolbar>
					<ToolbarSpacer/>
					<Button type="Accept" text="Accept"/>
					<Button type="Reject" text="Reject"/>
				</OverflowToolbar>
			</f:footer>
		</f:DynamicPage>
</mvc:View>