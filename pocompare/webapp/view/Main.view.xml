<mvc:View controllerName="com.sap.pocompare.controller.Main"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.uxap"
    xmlns:m="sap.m"
    xmlns:core="sap.ui.core"
	xmlns:layout="sap.ui.layout"
	xmlns:f="sap.f"
	class="sapuiSizeCompact"

    >
	<!-- <f:ShellBar
			title="BTP Harman POC"
			homeIcon="https://upload.wikimedia.org/wikipedia/commons/c/c2/Harman_International_logo.svg"
			notificationsNumber="2">
	</f:ShellBar> -->
	<m:Page showHeader="false">

	<m:content>
	<f:SidePanel id="mySidePanel" toggle="onToggle">
				<f:mainContent>
	
	
    	<ObjectPageLayout
		id="idObjectPageLayout"
		showFooter="true"
		showHeaderContent="true"
		toggleHeaderOnTitleClick="true"
		upperCaseAnchorBar="false">

		<headerTitle>
			<ObjectPageDynamicHeaderTitle>
				<heading>
					<core:Fragment fragmentName="com.sap.pocompare.view.fragments.Input" type="XML"/>
				</heading>
				<actions>
					<m:Button 
						text="Save Template" 
						icon="sap-icon://excel-attachment" 
						press=".onSaveTemplate" />
					<m:Button 
					visible="false"
						text="Download Template" 
						icon="sap-icon://excel-attachment" 
						press=".onDownloadTemplate" />
				</actions>
			</ObjectPageDynamicHeaderTitle>
		</headerTitle>

		<!-- <headerContent>
			<m:FlexBox id="idHeaderFB" wrap="Wrap" fitContainer="true" binding="{excelModel>/data/0}">

				<layout:VerticalLayout class="sapUiSmallMarginBeginEnd">
					<m:Label design="Bold" text="Vendor : {excelModel>Vendor} "/>
				</layout:VerticalLayout>
				<layout:VerticalLayout class="sapUiSmallMarginBeginEnd">
					<m:Label design="Bold" text="Material :  {excelModel>Material}"/>
				</layout:VerticalLayout>
				<layout:VerticalLayout class="sapUiSmallMarginBeginEnd">
					<m:Label design="Bold" text="Material Desc : {excelModel>MaterialDesc}"/>
				</layout:VerticalLayout>
			</m:FlexBox>
		</headerContent> -->

		<sections>
			<core:Fragment fragmentName="com.sap.pocompare.view.fragments.sections.POTable" type="XML"/>
		</sections>
		<footer>
			<m:OverflowToolbar>
				<m:ToolbarSpacer/>
				<m:Button type="Accept" text="Submit" press="onSubmitData"/>
			</m:OverflowToolbar>
		</footer>

	</ObjectPageLayout>
	</f:mainContent>
				<f:items>
					<f:SidePanelItem  icon="sap-icon://document" text="PO Line Item">
						<core:Fragment fragmentName="com.sap.pocompare.view.fragments.sections.POSidePanel" type="XML"/>
						
					</f:SidePanelItem>
				</f:items>
			</f:SidePanel>
			</m:content>
			</m:Page>
	
</mvc:View>