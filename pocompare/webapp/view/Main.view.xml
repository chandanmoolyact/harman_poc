<mvc:View
    controllerName="com.sap.pocompare.controller.Main"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.uxap"
    xmlns:m="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:layout="sap.ui.layout"
    xmlns:f="sap.f"
    class="sapUiSizeCompact"
>
    <m:Page showHeader="false">
        <m:content>
            <f:SidePanel
                id="mySidePanel"
                toggle="onToggle"
            >
                <f:mainContent>
                    <ObjectPageLayout
                        id="idObjectPageLayout"
                        showFooter="false"
                        showHeaderContent="true"
                        toggleHeaderOnTitleClick="true"
                        upperCaseAnchorBar="false"
                    >
                        <headerTitle>
                            <ObjectPageDynamicHeaderTitle>
                                <heading>
                                    <core:Fragment
                                        fragmentName="com.sap.pocompare.view.fragments.Input"
                                        type="XML"
                                    />
                                </heading>
                                <actions>
                                    <m:Button
                                        text="Save Template"
                                        icon="sap-icon://excel-attachment"
                                        press=".onSaveTemplate"
                                    />
                                    <m:Button
                                        visible="false"
                                        text="Download Template"
                                        icon="sap-icon://excel-attachment"
                                        press=".onDownloadTemplate"
                                    />
                                </actions>
                            </ObjectPageDynamicHeaderTitle>
                        </headerTitle>
                        <sections>
                            <core:Fragment
                                fragmentName="com.sap.pocompare.view.fragments.sections.POTable"
                                type="XML"
                            />
                        </sections>
                        <footer>
                            <m:OverflowToolbar>
                                <m:ToolbarSpacer />
                                <m:Button
                                    type="Accept"
                                    text="Submit"
                                    press="onSubmitData"
                                />
                            </m:OverflowToolbar>
                        </footer>
                    </ObjectPageLayout>
                </f:mainContent>
                <f:items>
                    <f:SidePanelItem
                        icon="sap-icon://document"
                        text="PO Line Item"
                    >
                        <core:Fragment
                            fragmentName="com.sap.pocompare.view.fragments.sections.POSidePanel"
                            type="XML"
                        />
                    </f:SidePanelItem>
                </f:items>
            </f:SidePanel>
        </m:content>
    </m:Page>
</mvc:View>
