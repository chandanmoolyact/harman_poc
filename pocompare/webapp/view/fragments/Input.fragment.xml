<core:FragmentDefinition
	xmlns="sap.m"
	xmlns:u="sap.ui.unified"
	xmlns:core="sap.ui.core">
	<HBox >
	<Title text="PO Excel Upload : " wrapping="true" class="sapUiTinyMarginTop"/>
	<u:FileUploader
	class="sapUiTinyMarginTop"
		id="excelUploader"
		name="excelUpload"
		buttonText="Browse..."
		icon="sap-icon://excel-attachment"
		tooltip="Select your Excel file"
		fileType="xlsx,xls"
		change="onFileChange"
		style="Emphasized"
		placeholder="Choose an Excel file (.xlsx, .xls)" 
		width="400px"/>
	</HBox>
</core:FragmentDefinition>