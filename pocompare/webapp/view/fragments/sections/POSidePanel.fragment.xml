<core:FragmentDefinition
	xmlns="sap.m"
	xmlns:core="sap.ui.core"
	xmlns:layout="sap.ui.layout"
	xmlns:uxap="sap.uxap">
    <Panel visible="{alSidePanel>NextPanelVisible}" width="auto" accessibleRole="Region">
        <content>
        <ScrollContainer height="600px" vertical="true" horizontal="false">
        <Table id="idPOItemsSPTable"
            mode="None"
            showSeparators="All"
            backgroundDesign="Transparent"
            class="sapUiSizeCompact"
            items="{alSidePanel>/}">
            <headerToolbar>
                <OverflowToolbar>
                    <content>
                        <Title text="Vendor PO Items" level="H2"/>
                        <ToolbarSpacer />
                        <Button text="+ Add row" type="Transparent" press=".onAddVendorRowSP"  />
                    </content>
                </OverflowToolbar>
            </headerToolbar>
            <columns>
                <Column 
                minScreenWidth="Tablet"
                    demandPopin="true" popinDisplay="Inline"
                    hAlign="Center">
                    <Text text="Quantity" wrapping="true" />
                </Column>
                <Column 
                minScreenWidth="10000px"
                    demandPopin="true" popinDisplay="Inline"
                    hAlign="Center">
                    <Text text="Delivery Date" wrapping="true" />
                </Column>
                <Column 
                minScreenWidth="10000px"
                    demandPopin="true" popinDisplay="Inline"
                    hAlign="Center">
                    <Text text="Status" wrapping="true" />
                </Column>
                <Column 
                minScreenWidth="10000px"
                    demandPopin="true" popinDisplay="Inline"
                    hAlign="Center">
                    <Text text="Action" wrapping="true" />
                </Column>
                
            </columns>
            <items>
                <ColumnListItem press=".onConfirmationRowPress" type="Active">
                    <cells>
                        <Input value="{alSidePanel>Quantity}" editable="true"/>
                        <DatePicker value="{alSidePanel>DeliveryDate}" valueFormat="yyyy-MM-dd" displayFormat="MM/dd/yyyy" />
                        <!-- <Text text="{alSidePanel>Status}" /> -->
                        <ObjectStatus inverted="true" text="{alSidePanel>StatusMsg}" state="{path:'alSidePanel>StatusState'}"></ObjectStatus>
                        <FlexBox fitContainer="true" wrap="Wrap" alignItems="Center" justifyContent="Center">
                            <Button press="onActionTaken" text="Approve" type="Accept" icon="sap-icon://accept"/>
                            <Button press="onActionTaken" text="Reject"  type="Reject" icon="sap-icon://decline"/>
                            <Button icon="sap-icon://delete" type="Reject" press=".onDeleteVendorRowSP" />
                        </FlexBox>
                    </cells>
                </ColumnListItem>
            </items>
        </Table>
        </ScrollContainer>
        </content>
    </Panel>		
</core:FragmentDefinition>