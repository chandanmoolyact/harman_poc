<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:layout="sap.ui.layout"
    xmlns:uxap="sap.uxap"
>
    <Table
        id="idPOTable"
        items="{
						path: 'excelModel>/data'
					}"
    >
        <columns>
            <Column
                minScreenWidth="Tablet"
                demandPopin="true"
                hAlign="Center"
            >
                <Text
                    text="PO Number"
                    wrapping="true"
                />
            </Column>
            <Column
                minScreenWidth="Tablet"
                demandPopin="true"
                popinDisplay="Inline"
                hAlign="Center"
            >
                <Text
                    text="Vendor"
                    wrapping="true"
                />
            </Column>
            <Column
                minScreenWidth="Tablet"
                demandPopin="true"
                popinDisplay="Inline"
                hAlign="Center"
            >
                <Text
                    text="Vendor Description"
                    wrapping="true"
                />
            </Column>
            <Column
                minScreenWidth="Tablet"
                demandPopin="true"
                popinDisplay="Inline"
                hAlign="Center"
            >
                <Text
                    text="PO Date"
                    wrapping="true"
                />
            </Column>
            <Column 
                minScreenWidth="10000px"
                demandPopin="true"
                popinDisplay="WithoutHeader"
                visible="true"
            >
                <Text text="Additional Details" />
            </Column>
        </columns>
        <items>
            <ColumnListItem
                type="Active"
                press=".onShowExpanded"
            >
                <cells>
                    <ObjectIdentifier title="{excelModel>PONumber}" />
                    <Text text="{excelModel>VendorCode}" />
                    <Text text="{excelModel>VendorName}" />
                    <FlexBox
                        fitContainer="true"
                        wrap="Wrap"
                        alignItems="Center"
                        justifyContent="Center"
                    >
                        <Text text="{excelModel>PODate}" />
                        <Button
                            type="Transparent"
                            icon="sap-icon://dropdown"
                            press="onShowExpanded"
                        />
                    </FlexBox>

                    <Panel
                    
                        visible="{excelModel>PanelVisible}"
                        width="auto"
                        accessibleRole="Region"
                    >
                        <content>
                            <VBox class="sapUiTinyMarginTop customPanelBorder">
                                <Table
                                    id="confirmationsTable"
                                    showSeparators="All"
                                    backgroundDesign="Transparent"
                                    class="sapUiSizeCompact"
                                    items="{excelModel>children}"
                                    mode="None" 
                                >
                                    <columns>
                                        <Column
                                            minScreenWidth="Tablet"
                                            demandPopin="true"
                                            hAlign="Center"
                                        >
                                            <Text
                                                text="Item No."
                                                wrapping="true"
                                            />
                                        </Column>
                                        <Column
                                            minScreenWidth="Tablet"
                                            demandPopin="true"
                                            popinDisplay="Inline"
                                            hAlign="Center"
                                        >
                                            <Text
                                                text="Material"
                                                wrapping="true"
                                            />
                                        </Column>
                                        <Column
                                            minScreenWidth="Tablet"
                                            demandPopin="true"
                                            popinDisplay="Inline"
                                            hAlign="Center"
                                        >
                                            <Text
                                                text="Material Description"
                                                wrapping="true"
                                            />
                                        </Column>
                                        <Column
                                            minScreenWidth="Tablet"
                                            demandPopin="true"
                                            popinDisplay="Inline"
                                            hAlign="Center"
                                        >
                                            <Text
                                                text="PO Quantity"
                                                wrapping="true"
                                            />
                                        </Column>
                                        <Column
                                            minScreenWidth="Tablet"
                                            demandPopin="true"
                                            popinDisplay="Inline"
                                            hAlign="Center"
                                        >
                                            <Text
                                                text="Unit of Measure"
                                                wrapping="true"
                                            />
                                        </Column>
                                        <Column
                                            minScreenWidth="Tablet"
                                            demandPopin="true"
                                            popinDisplay="Inline"
                                            hAlign="Center"
                                        >
                                            <Text
                                                text="Net Price"
                                                wrapping="true"
                                            />
                                        </Column>
                                        <Column
                                            minScreenWidth="Tablet"
                                            demandPopin="true"
                                            popinDisplay="Inline"
                                            hAlign="Center"
                                        >
                                            <Text
                                                text="Currency"
                                                wrapping="true"
                                            />
                                        </Column>
                                        <Column
                                            minScreenWidth="Tablet"
                                            demandPopin="true"
                                            popinDisplay="Inline"
                                            hAlign="Center"
                                        >
                                            <Text
                                                text="Per"
                                                wrapping="true"
                                            />
                                        </Column>
                                        <Column
                                            minScreenWidth="Tablet"
                                            demandPopin="true"
                                            popinDisplay="Inline"
                                            hAlign="Center"
                                        >
                                            <Text
                                                text="Material Group"
                                                wrapping="true"
                                            />
                                        </Column>
                                        <Column
                                            minScreenWidth="Tablet"
                                            demandPopin="true"
                                            popinDisplay="Inline"
                                            hAlign="Center"
                                        >
                                            <Text
                                                text="Plant"
                                                wrapping="true"
                                            />
                                        </Column>
                                        <Column
                                            minScreenWidth="Tablet"
                                            demandPopin="true"
                                            popinDisplay="Inline"
                                            hAlign="Center"
                                        >
                                            <Text
                                                text="Storage Location"
                                                wrapping="true"
                                            />
                                        </Column>

                                        <Column
                                            minScreenWidth="Tablet"
                                            demandPopin="true"
                                            popinDisplay="Inline"
                                            hAlign="Center"
                                        >
                                            <Text
                                                text="Delivery Date"
                                                wrapping="true"
                                            />
                                        </Column>
                                    </columns>
                                    <items>
                                        <ColumnListItem
                                            press=".onConfirmationRowPress"
                                            type="Active"
                                        >
                                            <cells>
                                                <Text
                                                    text="{excelModel>LineItemNumber}"
                                                    wrapping="true"
                                                />
                                                <Text
                                                    text="{excelModel>Material}"
                                                    wrapping="true"
                                                />
                                                <Text
                                                    text="{excelModel>MaterialDesc}"
                                                    wrapping="true"
                                                />
                                                <Text
                                                    text="{excelModel>POQuantity}"
                                                    wrapping="true"
                                                />
                                                <Text
                                                    text="{excelModel>UOM}"
                                                    wrapping="true"
                                                />
                                                <Text
                                                    text="{excelModel>NetPrice}"
                                                    wrapping="true"
                                                />
                                                <Text
                                                    text="{excelModel>Currency}"
                                                    wrapping="true"
                                                />
                                                <Text
                                                    text="{excelModel>Per}"
                                                    wrapping="true"
                                                />
                                                <Text
                                                    text="{excelModel>MaterialGroup}"
                                                    wrapping="true"
                                                />
                                                <Text
                                                    text="{excelModel>Plant}"
                                                    wrapping="true"
                                                />
                                                <Text
                                                    text="{excelModel>StorageLocation}"
                                                    wrapping="true"
                                                />
                                                <Text
                                                    text="{excelModel>DeliveryDate}"
                                                    wrapping="true"
                                                />
                                            </cells>
                                        </ColumnListItem>
                                    </items>
                                </Table>

                                <Table
                                    id="idPOItemsDataTable"
                                    mode="None"
                                    showSeparators="All"
                                    class="sapUiSizeCompact sapUiSmallMarginTop blueTableHighlight customLightBlueTable"
                                    items="{alSidePanel>/}"
                                >
                                    <headerToolbar >
                                        <OverflowToolbar > 
                                            <content>
                                                <Title
                                                    text="PO Confirmation Lines"
                                                    level="H2"
                                                />
                                                <ToolbarSpacer />
                                                <Button
                                                    text="+ Add row"
                                                    type="Transparent"
                                                    press=".onAddVendorRowSP"
                                                />
                                                <Button
                                                    text="Approve"
                                                    type="Accept"
                                                    press=".onActionTaken"
                                                />
                                                <Button
                                                    text="Reject"
                                                    type="Reject"
                                                    press=".onActionTaken"
                                                />
                                            </content>
                                        </OverflowToolbar>
                                    </headerToolbar>
                                    <columns>
                                        <Column
                                            minScreenWidth="Tablet"
                                            demandPopin="true"
                                            popinDisplay="Inline"
                                            hAlign="Center"
                                        >
                                            <Text
                                                text="CC"
                                                tooltip="Confirmation Category"
                                                wrapping="true"
                                            />
                                        </Column>

                                        <Column
                                            minScreenWidth="Tablet"
                                            demandPopin="true"
                                            popinDisplay="Inline"
                                            hAlign="Center"
                                            width="2rem"
                                        >
                                            <Text
                                                text="D"
                                                tooltip="Delivery Date Category"
                                                wrapping="true"
                                            />
                                        </Column>

                                        <Column
                                            minScreenWidth="Tablet"
                                            demandPopin="true"
                                            popinDisplay="Inline"
                                            hAlign="Center"
                                        >
                                            <Text
                                                text="Reference"
                                                wrapping="true"
                                            />
                                        </Column>

                                        

                                        <Column
                                            minScreenWidth="Tablet"
                                            demandPopin="true"
                                            popinDisplay="Inline"
                                            hAlign="Center"
                                        >
                                            <Text
                                                text="Inbound Delivery"
                                                wrapping="true"
                                            />
                                        </Column>

                                        <Column
                                            minScreenWidth="Tablet"
                                            demandPopin="true"
                                            popinDisplay="Inline"
                                            hAlign="Center"
                                        >
                                            <Text
                                                text="Item"
                                                wrapping="true"
                                            />
                                        </Column>

                                        <Column
                                            minScreenWidth="Desktop"
                                            demandPopin="true"
                                            popinDisplay="Inline"
                                            hAlign="Center"
                                        >
                                            <Text
                                                text="HL Item"
                                                wrapping="true"
                                            />
                                        </Column>

                                        <Column
                                            minScreenWidth="Tablet"
                                            demandPopin="true"
                                            popinDisplay="Inline"
                                            hAlign="Center"
                                        >
                                            <Text
                                                text="Batch"
                                                wrapping="true"
                                            />
                                        </Column>

                                        <Column
                                            minScreenWidth="Desktop"
                                            demandPopin="true"
                                            popinDisplay="Inline"
                                            hAlign="Center"
                                        >
                                            <Text
                                                text="Qty Reduced"
                                                wrapping="true"
                                            />
                                        </Column>

                                        <Column
                                            minScreenWidth="Desktop"
                                            demandPopin="true"
                                            popinDisplay="Inline"
                                            hAlign="Center"
                                        >
                                            <Text
                                                text="MRP Relevant"
                                                wrapping="true"
                                            />
                                        </Column>

                                        <Column
                                            minScreenWidth="Tablet"
                                            demandPopin="true"
                                            popinDisplay="Inline"
                                            hAlign="Center"
                                        >
                                            <Text
                                                text="MRP Material"
                                                wrapping="true"
                                            />
                                        </Column>

                                        <Column
                                            minScreenWidth="Desktop"
                                            demandPopin="true"
                                            popinDisplay="Inline"
                                            hAlign="Center"
                                            tooltip="Creation Indicator"
                                            width="2rem"
                                        >
                                            <Text
                                                text="CI"
                                                tooltip="Creation Indicator"
                                                wrapping="true"
                                                
                                            />
                                        </Column>

                                        <Column
                                            minScreenWidth="Desktop"
                                            demandPopin="true"
                                            popinDisplay="Inline"
                                            hAlign="Center"
                                            tooltip="Sequence Number"
                                            width="2rem"
                                        >
                                            <Text
                                                text="SN"
                                                 tooltip="Sequence Number"
                                                wrapping="true"
                                            />
                                        </Column>

                                        <Column
                                            minScreenWidth="Tablet"
                                            demandPopin="true"
                                            popinDisplay="Inline"
                                            hAlign="Center"
                                        >
                                            <Text
                                                text="Quantity"
                                                wrapping="true"
                                            />
                                        </Column>

                                        <Column
                                            minScreenWidth="Desktop"
                                            demandPopin="true"
                                            popinDisplay="Inline"
                                            hAlign="Center"
                                            width="9rem"
                                        >
                                            <Text
                                                text="Delivery Date"
                                                wrapping="true"
                                            />
                                        </Column>

                                        <Column
                                            minScreenWidth="Tablet"
                                            demandPopin="true"
                                            popinDisplay="Inline"
                                            hAlign="Center"
                                        >
                                            <Text
                                                text="Action"
                                                wrapping="true"
                                            />
                                        </Column>
                                    </columns>
                                    <items>
                                        <ColumnListItem
                                            type="Active"
                                        >
                                            <cells>
                                                <Text
                                                    text="{alSidePanel>ConfirmationCategory}"
                                                    wrapping="true"
                                                />

                                                <Text
                                                    text="{alSidePanel>FDDCategory}"
                                                    wrapping="true"
                                                />

                                                <Input
                                                    value="{alSidePanel>Reference}"
                                                    editable="{alSidePanel>newRecFlag}"
                                                    tooltip="{alSidePanel>Reference}"
                                                />
                                                

                                                <Text
                                                    text="{alSidePanel>InboundDelivery}"
                                                    wrapping="true"
                                                />

                                                <Text
                                                    text="{alSidePanel>Item}"
                                                    wrapping="true"
                                                />

                                                <Text
                                                    text="{alSidePanel>HLItem}"
                                                    wrapping="true"
                                                />

                                                <Input
                                                    value="{alSidePanel>Batch}"
                                                    editable="{alSidePanel>newRecFlag}"
                                                    tooltip="{alSidePanel>Batch}"
                                                    
                                                />

                                                <Text
                                                    text="{alSidePanel>QtyReduced}"
                                                    wrapping="true"
                                                />

                                                <Text
                                                    text="{alSidePanel>MRPRelevant}"
                                                    wrapping="true"
                                                />

                                                <Input
                                                    value="{alSidePanel>MRPMaterial}"
                                                    editable="{alSidePanel>newRecFlag}"
                                                    tooltip="{alSidePanel>MRPMaterial}"
                                                />

                                                <Text
                                                    text="{alSidePanel>CreationIndicator}"
                                                    wrapping="true"
                                                />

                                                <Text
                                                    text="{alSidePanel>SequenceNumber}"
                                                    wrapping="true"
                                                />
                                                <Input
                                                    value="{alSidePanel>Quantity}"
                                                    editable="{= ${alSidePanel>ConfirmationCategory} === 'LA' ? false : true }"
                                                    tooltip="{alSidePanel>Quantity}"
                                                />
                                                <DatePicker
                                                    value="{alSidePanel>CreationDate}"
                                                    valueFormat="yyyy-MM-dd"
                                                    displayFormat="MM/dd/yyyy"
                                                    enabled="{= ${alSidePanel>ConfirmationCategory} === 'LA' ? false : true }"
                                                    tooltip="{alSidePanel>CreationDate}"
                                                />
                                                <Button
                                                    icon="sap-icon://delete"
                                                    type="Reject"
                                                    press=".onDeleteVendorRowSP"
                                                    enabled="{= ${alSidePanel>ConfirmationCategory} === 'LA' ? false : true }"
                                                />
                                            </cells>
                                        </ColumnListItem>
                                    </items>
                                </Table>
                            </VBox>
                        </content>
                    </Panel>
                </cells>
            </ColumnListItem>
        </items>
    </Table>
</core:FragmentDefinition>
