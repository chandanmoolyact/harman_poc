<core:FragmentDefinition
	xmlns="sap.m"
	xmlns:core="sap.ui.core"
	xmlns:uxap="sap.uxap">
	<uxap:ObjectPageSection title="Purchase Order Items" visible="true" titleUppercase="false">
		<uxap:subSections>
			<uxap:ObjectPageSubSection>
				<Table
					id="idProductsTable"
					items="{
						path: 'excelModel>/data'
					}"
					sticky="ColumnHeaders"
					class="sapUxAPObjectPageSubSectionAlignContent"
					width="auto">
					<columns>
						<Column width="12rem">
							<Text text="PO Number" />
						</Column>
						<Column
							minScreenWidth="Tablet"
							demandPopin="true"
							hAlign="Center">
							<Text text="Line Item" />
						</Column>
						<Column
							minScreenWidth="Tablet"
							demandPopin="true"
							popinDisplay="Inline"
							hAlign="Center">
						<Text text="Quantity" />
						</Column>
						<Column hAlign="Center">
							<Text text="Delivery Date" />
						</Column>
						<Column hAlign="Center">
							<Text text="Actions" />
						</Column>
						<Column hAlign="Center">
							<Text text="Status" />
						</Column>
					</columns>
					<items>
						<ColumnListItem type="Navigation" press=".onRowPress">
							<cells>
								<ObjectIdentifier title="{excelModel>PONumber}" />
								<Text text="{excelModel>LineItem}" />
								<Text text="{excelModel>Quantity}" />
								<Text text="{excelModel>DeliveryDate}" />
								<FlexBox fitContainer="true" wrap="Wrap" alignItems="Center" justifyContent="Center">
									<Button type="Accept" icon="sap-icon://accept"></Button>
									<Button type="Reject" icon="sap-icon://decline"></Button>
								</FlexBox>
								<ObjectStatus inverted="true" text="{excelModel>Status}" state="{path:'excelModel>StatusState'}"></ObjectStatus>
								<Panel visible="{excelModel>PanelVisible}">
								</Panel>
							</cells>
						</ColumnListItem>
					</items>
				</Table>
			</uxap:ObjectPageSubSection>
		</uxap:subSections>
	</uxap:ObjectPageSection>
</core:FragmentDefinition>