<core:FragmentDefinition
	xmlns="sap.m"
	xmlns:core="sap.ui.core"
	xmlns:layout="sap.ui.layout"
	xmlns:uxap="sap.uxap">
	<uxap:ObjectPageSection title="Purchase Order Items" visible="true" titleUppercase="false">
		<uxap:subSections>
			<uxap:ObjectPageSubSection>
				<Table
					id="idProductsTable"
					items="{
						path: 'excelModel>/data'
					}"
					sticky="ColumnHeaders"
					class="sapUxAPObjectPageSubSectionAlignContent"
					width="auto">
					<columns>
						<Column width="12rem" minScreenWidth="Tablet"
							demandPopin="true" 
							hAlign="Center">
							<Text text="PO Number" wrapping="true" />
						</Column>
						<Column minScreenWidth="Tablet"
							demandPopin="true" popinDisplay="Inline"
							hAlign="Center" >
							<Text text="Vendor" wrapping="true" />
						</Column>
						<Column minScreenWidth="Tablet"
							demandPopin="true" popinDisplay="Inline"
							hAlign="Center">
							<Text text="Material" wrapping="true" />
						</Column>
						<Column minScreenWidth="Tablet"
							demandPopin="true" popinDisplay="Inline"
							hAlign="Center">
							<Text text="Material Description" wrapping="true" />
						</Column>
						<Column
							minScreenWidth="Tablet"
							demandPopin="true" popinDisplay="Inline"
							hAlign="Center">
							<Text text="Line Item" wrapping="true" />
						</Column>
						<Column
							minScreenWidth="Tablet"
							demandPopin="true" popinDisplay="Inline"
							hAlign="Center">
						<Text text="Quantity" wrapping="true" />
						</Column>
						<Column 
						minScreenWidth="Tablet"
							demandPopin="true" popinDisplay="Inline"
							hAlign="Center">
							<Text text="Delivery Date" wrapping="true" />
						</Column>
						<Column minScreenWidth="Tablet"
							demandPopin="true"
							hAlign="Center" popinDisplay="Inline">
							<Text text="Status" wrapping="true"/>
						</Column>
						<Column minScreenWidth="10000px" demandPopin="true" popinDisplay="WithoutHeader">
							<Text text="Additional Details" />
						</Column>
					</columns>
					<items>
						<ColumnListItem type="Active" press=".onRowPress">
							<cells>
								<ObjectIdentifier title="{excelModel>PONumber}" />
								<Text text="{excelModel>Vendor}" />
								<Text text="{excelModel>Material}" />
								<Text text="{excelModel>MaterialDesc}" />
								<Text text="{excelModel>LineItem}" />
								<Text text="{excelModel>Quantity}" />
								<Text text="{excelModel>DeliveryDate}" />
								<FlexBox fitContainer="true" wrap="Wrap" alignItems="Center" justifyContent="Center">
									<ObjectStatus inverted="true" text="{excelModel>Status}" state="{path:'excelModel>StatusState'}"></ObjectStatus>
									<Button type="Transparent" icon="sap-icon://dropdown" press="onShowExpanded"></Button>  
								</FlexBox>
								
								<!-- <Panel visible="{excelModel>PanelVisible}">
									<core:Fragment fragmentName="com.sap.pocompare.view.fragments.sections.ComparePanel" type="XML"/>
								</Panel> -->


								<Panel visible="{excelModel>PanelVisible}" width="auto" accessibleRole="Region">
									<headerToolbar>
										<OverflowToolbar>
											<Title text="COMPARISON — PO {excelModel>PONumber} / LINE {excelModel>LineItem}"/>
										</OverflowToolbar>
									</headerToolbar>




									<content>
										<layout:Grid defaultSpan="L6 M6 S6" class="sapUiSmallMargin">
											
											<VBox class="sapUiTinyMarginEnd" style="border: 2px solid #000; border-radius: 4px; padding: 4px;">
												<HBox style="background-color: #e3ebf6; padding: 4px 8px; border-radius: 4px;" class="sapUiTinyMarginBottom">
													<Title text="Vendor Uploaded Info" level="H6" style="color: #0b4a99;" />
												</HBox>
												
												<Table mode="None" showSeparators="Inner" backgroundDesign="Solid" class="sapUiSizeCompact" items="{excelModel>VendorInputTable}">
													<columns>
														<Column minScreenWidth="Tablet"
														demandPopin="true" popinDisplay="Inline"
														hAlign="Center" width="30%"><Text text="Quantity" style="color: #0b4a99; font-weight: bold;" /></Column>
																					<Column minScreenWidth="Tablet"
														demandPopin="true" popinDisplay="Inline"
														hAlign="Center" width="50%"><Text text="Delivery Date" style="color: #0b4a99; font-weight: bold;" /></Column>
																					<Column minScreenWidth="Tablet"
														demandPopin="true" popinDisplay="Inline"
														hAlign="Center" width="20%" ><Text text="Delete" style="color: #0b4a99; font-weight: bold;"/></Column>
													</columns>
													<items>
														<ColumnListItem>
															<cells>
																<Input value="{excelModel>Quantity}" />
																<DatePicker value="{excelModel>DeliveryDate}" valueFormat="yyyy-MM-dd" displayFormat="MM/dd/yyyy" />
																<Button icon="sap-icon://delete" type="Reject" press=".onDeleteVendorRow" />
															</cells>
														</ColumnListItem>
													</items>
												</Table>
												
												<HBox class="sapUiTinyMargin">
													<Button text="+ Add row" type="Transparent" press=".onAddVendorRow" style="color: #0b4a99; border: 1px dashed #0b4a99;" />
												</HBox>
											</VBox>

											<VBox style="background-color: #f7f9fa; border-radius: 4px; padding: 4px;">
												<HBox style="padding: 4px 8px;" class="sapUiTinyMarginBottom">
													<Title text="SAP PO Data" level="H6" style="color: #555;" />
												</HBox>
												
												<Table mode="None" showSeparators="Inner" backgroundDesign="Transparent">
													<columns>
														<Column minScreenWidth="Tablet"
							demandPopin="true" popinDisplay="Inline"
							hAlign="Center"
														width="30%"><Text text="Quantity" style="color: #555; font-weight: bold;" /></Column>
														<Column minScreenWidth="Tablet"
							demandPopin="true" popinDisplay="Inline"
							hAlign="Center" width="70%"><Text text="Delivery Date" style="color: #555; font-weight: bold;" /></Column>
													</columns>
													<items>
														<ColumnListItem>
															<cells>
																<Text text="10" />
																<Text text="02/12/2026" />
															</cells>
														</ColumnListItem>
													</items>
												</Table>
											</VBox>
											
										</layout:Grid>
										<VBox >
												<FlexBox fitContainer="true" wrap="Wrap" alignItems="Center" justifyContent="End">
													<Button press="onActionTaken" text="Approve" type="Accept" icon="sap-icon://accept"></Button>
													<Button press="onActionTaken" text="Reject" type="Reject" icon="sap-icon://decline"></Button>
												</FlexBox>
											</VBox>
									</content>
									
								</Panel>
								
							</cells>
						</ColumnListItem>
					</items>
				</Table>
			</uxap:ObjectPageSubSection>
		</uxap:subSections>
	</uxap:ObjectPageSection>
</core:FragmentDefinition>