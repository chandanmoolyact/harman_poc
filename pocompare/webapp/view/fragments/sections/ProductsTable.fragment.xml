<core:FragmentDefinition
	xmlns="sap.m"
	xmlns:core="sap.ui.core"
	xmlns:uxap="sap.uxap">
	<uxap:ObjectPageSection title="Purchase Order Items" visible="true" titleUppercase="false">
		<uxap:subSections>
			<uxap:ObjectPageSubSection>
				<Table
					id="idProductsTable"
					items="{
						path: 'excelModel>/data'
					}"
					class="sapUxAPObjectPageSubSectionAlignContent"
					width="auto">
					<columns>
						<Column width="12rem">
							<Text text="PO Number" />
						</Column>
						<Column
							minScreenWidth="Tablet"
							demandPopin="true"
							hAlign="Center">
							<Text text="Line Item" />
						</Column>
						<Column
							minScreenWidth="Tablet"
							demandPopin="true"
							popinDisplay="Inline"
							hAlign="Center">
						<Text text="Quantity" />
						</Column>
						<Column hAlign="Center">
							<Text text="Delivery Date" />
						</Column>
					</columns>
					<items>
						<ColumnListItem>
							<cells>
								<Text text="{excelModel>PONumber}" />
								<Text text="{excelModel>LineItem}" />
								<Text text="{excelModel>Quantity}" />
								<Text text="{excelModel>DeliveryDate}" />
							</cells>
						</ColumnListItem>
					</items>
				</Table>
			</uxap:ObjectPageSubSection>
		</uxap:subSections>
	</uxap:ObjectPageSection>
</core:FragmentDefinition>