<core:FragmentDefinition
	xmlns="sap.m"
	xmlns:core="sap.ui.core"
	xmlns:layout="sap.ui.layout"
	xmlns:uxap="sap.uxap">
	<uxap:ObjectPageSection title="Purchase Order Items" visible="true" titleUppercase="false">
		<uxap:subSections>
			<uxap:ObjectPageSubSection>
				<Table
					id="idPOTable"
					items="{
						path: 'excelModel>/data'
					}"
					sticky="ColumnHeaders"
					class="sapUxAPObjectPageSubSectionAlignContent"
					width="auto">
					<columns>
						<Column minScreenWidth="Tablet"
							demandPopin="true" 
							hAlign="Center">
							<Text text="PO Number" wrapping="true" />
						</Column>
						<Column minScreenWidth="Tablet"
							demandPopin="true" popinDisplay="Inline"
							hAlign="Center" >
							<Text text="Vendor" wrapping="true" />
						</Column>
						<Column minScreenWidth="Tablet"
							demandPopin="true" popinDisplay="Inline"
							hAlign="Center" >
							<Text text="Vendor Description" wrapping="true" />
							
						</Column>
						<Column 
						minScreenWidth="Tablet"
							demandPopin="true" popinDisplay="Inline"
							hAlign="Center">
							<Text text="Document Date" wrapping="true" />
						</Column>
						<Column minScreenWidth="10000px" demandPopin="true" popinDisplay="WithoutHeader">
							<Text text="Additional Details" />
						</Column>
						
						
					</columns>
					<items>
						<ColumnListItem type="Active" press=".onRowPress">
							<cells>
								<ObjectIdentifier title="{excelModel>PONumber}" />
								<Text text="{excelModel>VendorCode}" />
								<Text text="{excelModel>VendorName}" />
								<FlexBox fitContainer="true" wrap="Wrap" alignItems="Center" justifyContent="Center">
									<Text text="{excelModel>DocumentDate}" />
									<Button type="Transparent" icon="sap-icon://dropdown" press="onShowExpanded"></Button>  
								</FlexBox>
								


								<Panel visible="{excelModel>PanelVisible}" width="auto" accessibleRole="Region">
									<content>
										<!-- TABLE 1: Confirmations List -->
										<Table id="confirmationsTable"
											mode="None"
											showSeparators="All"
											backgroundDesign="Transparent"
											class="sapUiSizeCompact"
											items="{excelModel>children}">
											<columns>
												<Column minScreenWidth="Tablet"
													demandPopin="true" 
													hAlign="Center">
													<Text text="Item No." wrapping="true" />
												</Column>
												<Column minScreenWidth="Tablet"
													demandPopin="true" popinDisplay="Inline"
													hAlign="Center" >
													<Text text="Material" wrapping="true" />
												</Column>
												<!-- <Column 
												minScreenWidth="Tablet"
													demandPopin="true" popinDisplay="Inline"
													hAlign="Center">
													<Text text="Quantity" wrapping="true" />
												</Column> -->
												<Column 
												minScreenWidth="Tablet"
													demandPopin="true" popinDisplay="Inline"
													hAlign="Center">
													<Text text="Delivery Date" wrapping="true" />
												</Column>
												<Column minScreenWidth="10000px" demandPopin="true" popinDisplay="WithoutHeader">
													<Text text="Additional Details" />
												</Column>
												
											</columns>
											<items>
												<ColumnListItem press=".onConfirmationRowPress" type="Active">
													<cells>
														<Text text="{excelModel>LineItemNumber}"/>
														<Text text="{excelModel>Material}"/>
														<!-- <Text text="{excelModel>Quantity}"/> -->
														<FlexBox fitContainer="true" wrap="Wrap" alignItems="Center" justifyContent="Center">
															<Text text="{excelModel>DeliveryDate}" />
															<Button type="Transparent" icon="sap-icon://dropdown" press="onSubShowExpanded"></Button>  
														</FlexBox>
														<Panel visible="{excelModel>NextPanelVisible}" width="auto" accessibleRole="Region">
															<content>
															<Table id="idPOItemsDataTable"
																mode="None"
																showSeparators="All"
																backgroundDesign="Transparent"
																class="sapUiSizeCompact"
																items="{excelModel>children}">
																<headerToolbar>
																	<OverflowToolbar>
																		<content>
																			<Title text="Vendor PO Items" level="H2"/>
																			<ToolbarSpacer />
																			<Button text="+ Add row" type="Transparent" press=".onAddVendorRow"  />
																		</content>
																	</OverflowToolbar>
																</headerToolbar>
																<columns>
																	<Column 
																	minScreenWidth="Tablet"
																		demandPopin="true" popinDisplay="Inline"
																		hAlign="Center">
																		<Text text="Quantity" wrapping="true" />
																	</Column>
																	<Column 
																	minScreenWidth="Tablet"
																		demandPopin="true" popinDisplay="Inline"
																		hAlign="Center">
																		<Text text="Delivery Date" wrapping="true" />
																	</Column>
																	<Column 
																	minScreenWidth="Tablet"
																		demandPopin="true" popinDisplay="Inline"
																		hAlign="Center">
																		<Text text="Action" wrapping="true" />
																	</Column>
																	
																</columns>
																<items>
																	<ColumnListItem press=".onConfirmationRowPress" type="Active">
																		<cells>
																			<Input value="{excelModel>Quantity}" editable="true"/>
																			<DatePicker value="{excelModel>DeliveryDate}" valueFormat="yyyy-MM-dd" displayFormat="MM/dd/yyyy" />
																			<Button icon="sap-icon://delete" type="Reject" press=".onDeleteVendorRow" />
																		</cells>
																	</ColumnListItem>
																</items>
															</Table>
															<!-- Approve / Reject -->
															<FlexBox fitContainer="true" wrap="Wrap" alignItems="Center" justifyContent="End" class="sapUiSmallMarginTop">
																<Button press="onActionTaken" text="Approve" type="Accept" icon="sap-icon://accept"/>
																<Button press="onActionTaken" text="Reject"  type="Reject" icon="sap-icon://decline"/>
															</FlexBox>
															</content>
														</Panel>
													</cells>
												</ColumnListItem>
											</items>
										</Table>
									</content>
								</Panel>
								
								
							</cells>
						</ColumnListItem>
					</items>
				</Table>
				<Dialog id="poDetailDialog"
					title="PO Lineitem"
					contentWidth="600px"
					resizable="true"
					draggable="true">
				<content>
					<Table id="idPOLIDataTable"
						mode="None"
						showSeparators="All"
						backgroundDesign="Transparent"
						class="sapUiSizeCompact">
						<columns>
							<Column minScreenWidth="Tablet"
								demandPopin="true" 
								hAlign="Center">
								<Text text="Item No." wrapping="true" />
							</Column>
							<Column minScreenWidth="Tablet"
								demandPopin="true" popinDisplay="Inline"
								hAlign="Center" >
								<Text text="Material" wrapping="true" />
							</Column>
							<Column 
							minScreenWidth="Tablet"
								demandPopin="true" popinDisplay="Inline"
								hAlign="Center">
								<Text text="Quantity" wrapping="true" />
							</Column>
							<Column 
							minScreenWidth="Tablet"
								demandPopin="true" popinDisplay="Inline"
								hAlign="Center">
								<Text text="Delivery Date" wrapping="true" />
							</Column>
							
						</columns>
						<items>
							<ColumnListItem press=".onConfirmationRowPress" type="Active">
								<cells>
									<Text text="{excelModel>LineItemNumber}"/>
									<Text text="{excelModel>Material}"/>
									<Text text="{excelModel>Quantity}"/>
									<Text text="{excelModel>DeliveryDate}"/>
								</cells>
							</ColumnListItem>
						</items>
					</Table>
				</content>
				<beginButton>
					<Button text="Close" press=".onCloseDialog"/>
				</beginButton>
			</Dialog>
			</uxap:ObjectPageSubSection>
		</uxap:subSections>
	</uxap:ObjectPageSection>
</core:FragmentDefinition>