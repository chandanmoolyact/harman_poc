<mvc:View controllerName="com.sap.pocompare.controller.Master"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.uxap"
    xmlns:m="sap.m"
    xmlns:core="sap.ui.core"
	class="sapuiSizeCompact"
    >
    	<ObjectPageLayout
		id="ObjectPageLayout"
		showFooter="true"
		showHeaderContent="true"
		toggleHeaderOnTitleClick="true"
		upperCaseAnchorBar="false">

		<headerTitle>
			<ObjectPageDynamicHeaderTitle>
				<heading>
					<!-- <m:Title text="PO Confirmation" /> -->
					<core:Fragment fragmentName="com.sap.pocompare.view.fragments.Input" type="XML"/>
				</heading>
				<actions>
					<m:Button 
						text="Download Template" 
						icon="sap-icon://excel-attachment" 
						press=".onDownloadTemplate" />
				</actions>
			</ObjectPageDynamicHeaderTitle>
		</headerTitle>

		<headerContent>
			<!-- <core:Fragment fragmentName="com.sap.pocompare.view.fragments.HeaderContent" type="XML"/> -->
		</headerContent>

		<sections>
			<!-- <core:Fragment fragmentName="com.sap.pocompare.view.fragments.sections.IllustratedMessage" type="XML"/> -->
			<core:Fragment fragmentName="com.sap.pocompare.view.fragments.sections.ProductsTable" type="XML"/>
			<!-- <core:Fragment fragmentName="com.sap.pocompare.view.fragments.sections.SupplierDetails" type="XML"/> -->
		</sections>
		<footer>
			<m:OverflowToolbar>
				<m:ToolbarSpacer/>
				<m:Button type="Accept" text="Submit" press="onSubmitData"/>
			</m:OverflowToolbar>
		</footer>

	</ObjectPageLayout>
</mvc:View>